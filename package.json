{
  "name": "codex-supervisor",
  "version": "0.1.7",
  "private": true,
  "description": "Issue-driven Codex quality layer for supervised GitHub PR delivery.",
  "license": "MIT",
  "homepage": "https://github.com/TommyKammy/codex-supervisor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TommyKammy/codex-supervisor.git"
  },
  "bugs": {
    "url": "https://github.com/TommyKammy/codex-supervisor/issues"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node dist/build-freshness.js",
    "guardrails:check": "tsx src/committed-guardrails-cli.ts check",
    "guardrails:fix": "tsx src/committed-guardrails-cli.ts fix",
    "verify:paths": "tsx scripts/check-workstation-local-paths.ts",
    "verify:subprocess-safety": "tsx scripts/check-subprocess-safety.ts",
    "verify:supervisor-pre-pr": "npm run verify:paths && npm run verify:subprocess-safety && npm run build",
    "verify:pre-pr": "npm run verify:paths && npm run verify:subprocess-safety && npm run build && npm test",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:managed-restart-regressions": "tsx --test src/managed-restart.test.ts src/backend/supervisor-http-server.test.ts src/backend/webui-dashboard.test.ts src/managed-restart-launcher-assets.test.ts src/ci-workflow.test.ts",
    "test:malformed-inventory-regressions": "tsx --test src/github/github.test.ts src/run-once-cycle-prelude.test.ts src/supervisor/supervisor-pr-review-blockers.test.ts src/supervisor/supervisor-diagnostics-status-selection.test.ts src/supervisor/supervisor-diagnostics-explain.test.ts",
    "test:webui-smoke": "tsx --test src/backend/webui-dashboard-browser-smoke.test.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "playwright-core": "^1.58.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
